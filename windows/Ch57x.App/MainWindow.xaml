<Window x:Class="Ch57x.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CH57x 설정기" Height="520" Width="680"
        Background="#0f1115" Foreground="#e6e9ef" FontSize="14">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <TextBlock x:Name="StatusText" Text="○ 미연결" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="ProfileText" Text="" Foreground="#8b93a1" Margin="14,0,0,0" VerticalAlignment="Center"/>
        </DockPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <Button x:Name="BtnConnect" Content="키보드 연결" Margin="0,0,8,8" Padding="12,6"/>
            <Button x:Name="BtnLoad" Content="JSON 가져오기 (병합)" Margin="0,0,8,8" Padding="12,6"/>
            <Button x:Name="BtnEdit" Content="키 편집" Margin="0,0,8,8" Padding="12,6"/>
            <Button x:Name="BtnUpload" Content="키보드에 업로드" Margin="0,0,8,8" Padding="12,6"/>
            <Button x:Name="BtnRead" Content="키보드에서 읽기" Margin="0,0,8,8" Padding="12,6"/>
            <Button x:Name="BtnSave" Content="프로필 저장" Margin="0,0,8,8" Padding="12,6"/>
            <Button x:Name="BtnClearLog" Content="로그 지우기" Margin="0,0,8,8" Padding="12,6"/>
            <Button x:Name="BtnOpenFolder" Content="프로필 폴더 열기" Margin="0,0,8,8" Padding="12,6"/>
        </WrapPanel>

        <ListBox x:Name="LogList" Grid.Row="2" Background="#0b0d11" Foreground="#9fe6a0"
                 BorderBrush="#2a2f3a" FontFamily="Consolas" FontSize="13"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
