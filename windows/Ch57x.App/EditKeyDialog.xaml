<Window x:Class="Ch57x.App.EditKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="키 편집" Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#181b22" Foreground="#e6e9ef" FontSize="14">
    <StackPanel Margin="16">
        <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>

        <TextBlock Text="별칭 (alias)" Foreground="#8b93a1" Margin="0,0,0,4"/>
        <TextBox x:Name="TxtAlias" MaxLength="20" Padding="8,6" Background="#21252e" Foreground="#e6e9ef"
                 BorderBrush="#2a2f3a" Margin="0,0,0,12" />

        <TextBlock Text="동작 종류" Foreground="#8b93a1" Margin="0,0,0,4"/>
        <WrapPanel x:Name="TypeBtns" Margin="0,0,0,12"/>

        <Border x:Name="BodyBorder" BorderBrush="#2a2f3a" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <StackPanel x:Name="Body"/>
        </Border>

        <DockPanel LastChildFill="False">
            <Button x:Name="BtnOk" Content="적용" Padding="14,7" Background="#2d6cdf" Foreground="White" BorderThickness="0"/>
            <Button x:Name="BtnClear" Content="이 키 비우기" Padding="14,7" Margin="8,0,0,0"/>
            <Button x:Name="BtnCancel" Content="취소" Padding="14,7" DockPanel.Dock="Right"/>
        </DockPanel>
    </StackPanel>
</Window>
