<Window x:Class="Ch57x.App.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CH57x HUD"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Opacity="0.92">
    <Border CornerRadius="10" Background="#dd0f1115" BorderBrush="#3a4250" BorderThickness="1" Padding="10">
        <StackPanel x:Name="Root" Orientation="Vertical">
            <DockPanel x:Name="HeaderPanel" Margin="0,0,0,6" LastChildFill="False">
                <TextBlock x:Name="ProfileName" Text="—" Foreground="#e6e9ef" FontSize="13" FontWeight="Bold"
                           DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <Button x:Name="BtnHide" Content="✕" DockPanel.Dock="Right" Width="20" Height="20"
                        Padding="0" FontSize="11" Background="Transparent" BorderThickness="0" Foreground="#8b93a1"/>
            </DockPanel>
            <StackPanel x:Name="LayerTabs" Orientation="Horizontal" Margin="0,0,0,6"/>
            <StackPanel x:Name="Device" Orientation="Horizontal"/>
        </StackPanel>
    </Border>
</Window>
